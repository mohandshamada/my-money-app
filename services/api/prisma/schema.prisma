generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model bank_accounts {
  id                   String           @id @default(cuid())
  bank_connection_id   String
  user_id              String
  plaid_account_id     String
  name                 String?
  account_type         String?
  account_subtype      String?
  current_balance      Decimal?         @db.Decimal(12, 2)
  available_balance    Decimal?         @db.Decimal(12, 2)
  is_hidden            Boolean          @default(false)
  include_in_net_worth Boolean          @default(true)
  synced_at            DateTime?
  bank_connections     bank_connections @relation(fields: [bank_connection_id], references: [id], onDelete: Cascade)

  @@unique([bank_connection_id, plaid_account_id])
  @@index([bank_connection_id])
  @@index([user_id])
}

model bank_connections {
  id                   String          @id @default(cuid())
  user_id              String
  provider             String          @default("plaid")
  plaid_access_token   String?
  plaid_item_id        String?
  institution_name     String?
  institution_logo_url String?
  last_synced_at       DateTime?
  next_sync_at         DateTime?
  sync_status          String          @default("pending")
  sync_error_message   String?
  sync_error_count     Int             @default(0)
  connected_at         DateTime        @default(now())
  disconnected_at      DateTime?
  bank_accounts        bank_accounts[]
  users                users           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions         transactions[]

  @@unique([user_id, plaid_item_id])
  @@index([sync_status])
  @@index([user_id])
}

model budgets {
  id          String    @id @default(cuid())
  user_id     String
  category    String
  amount      Decimal   @db.Decimal(12, 2)
  currency    String    @default("USD")
  period_type String
  start_date  DateTime
  end_date    DateTime?
  rollover    Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, category, start_date])
  @@index([start_date])
  @@index([user_id])
}

model forecasts {
  id                String   @id @default(cuid())
  user_id           String
  forecast_date     DateTime
  projected_balance Decimal? @db.Decimal(12, 2)
  confidence_level  Float?
  scenario_name     String?
  created_at        DateTime @default(now())
  users             users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, forecast_date, scenario_name])
  @@index([forecast_date])
  @@index([user_id])
}

model password_resets {
  id         String    @id @default(cuid())
  user_id    String
  token_hash String
  new_email  String? // For email change verification
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token_hash])
  @@index([user_id])
}

model refresh_tokens {
  id         String   @id @default(cuid())
  user_id    String
  token_hash String
  expires_at DateTime
  created_at DateTime @default(now())
  revoked    Boolean  @default(false)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model transactions {
  id                   String            @id @default(cuid())
  user_id              String
  bank_connection_id   String?
  amount               Decimal           @db.Decimal(12, 2)
  currency             String            @default("USD")
  is_expense           Boolean
  merchant             String?
  description          String?
  date                 DateTime
  category             String?
  subcategory          String?
  tags                 Json?             @default("[]")
  plaid_transaction_id String?
  account_id           String?
  pending              Boolean           @default(false)
  is_recurring         Boolean           @default(false)
  recurring_pattern    String?
  created_at           DateTime          @default(now())
  updated_at           DateTime
  bank_connections     bank_connections? @relation(fields: [bank_connection_id], references: [id])
  users                users             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, plaid_transaction_id])
  @@index([category])
  @@index([date])
  @@index([user_id, date])
  @@index([user_id])
}

model users {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  password_hash            String
  full_name                String?
  phone                    String?
  avatar_url               String?
  timezone                 String                    @default("UTC")
  currency                 String                    @default("USD")
  budget_type              String?
  notification_preferences Json?
  email_verified           Boolean                   @default(false)
  two_factor_enabled       Boolean                   @default(false)
  two_factor_secret        String?
  created_at               DateTime                  @default(now())
  updated_at               DateTime
  deleted_at               DateTime?
  google_id                String?                   @unique
  apple_id                 String?                   @unique
  microsoft_id             String?                   @unique
  facebook_id              String?                   @unique
  role                     String                    @default("user")
  bank_connections         bank_connections[]
  budgets                  budgets[]
  forecasts                forecasts[]
  password_resets          password_resets[]
  refresh_tokens           refresh_tokens[]
  transactions             transactions[]
  passkeys                 passkeys[]
  subscriptions            subscriptions[]
  user_settings            user_settings?
  categorization_rules     categorization_rules[]
  investments              investments[]
  investment_transactions  investment_transactions[]

  @@index([created_at])
  @@index([email])
}

model passkeys {
  id      String @id @default(cuid())
  user_id String
  user    users  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  credential_id String  @unique
  public_key    String
  sign_count    Int
  aaguid        String?

  name         String?
  device_type  String?
  created_at   DateTime  @default(now())
  last_used_at DateTime?

  @@index([user_id])
}

model subscriptions {
  id      String @id @default(cuid())
  user_id String
  user    users  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  name         String
  amount       Decimal  @db.Decimal(12, 2)
  currency     String   @default("USD")
  frequency    String   @default("monthly") // monthly, yearly, weekly
  next_billing DateTime
  category     String?
  auto_renew   Boolean  @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([next_billing])
}

model user_settings {
  id      String @id @default(cuid())
  user_id String @unique
  user    users  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // AI Provider Settings
  ai_provider String  @default("local") // local, openai, openrouter, zai, kimi
  ai_api_key  String? // Encrypted API key
  ai_model    String? // Model name (e.g., gpt-4, glm-5, etc.)
  ai_enabled  Boolean @default(false)

  // Subscription Tier
  subscription_tier       String    @default("basic") // basic, premium, enterprise
  subscription_expires_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
}

model exchange_rates {
  id              String   @id @default(cuid())
  base_currency   String
  target_currency String
  rate            Decimal  @db.Decimal(18, 8)
  updated_at      DateTime @updatedAt

  @@unique([base_currency, target_currency])
  @@index([base_currency])
  @@index([updated_at])
}

model categorization_rules {
  id          String   @id @default(cuid())
  user_id     String
  users       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  match_field String // e.g., 'merchant', 'description'
  match_type  String // e.g., 'contains', 'exact', 'starts_with'
  match_value String
  category    String
  subcategory String?
  priority    Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([user_id])
}

model investments {
  id         String   @id @default(cuid())
  user_id    String
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  symbol     String // e.g., 'AAPL', 'BTC'
  name       String
  asset_type String // e.g., 'stock', 'crypto', 'etf'
  quantity   Decimal  @db.Decimal(18, 8)
  avg_price  Decimal  @db.Decimal(18, 8) // in user's base currency
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
}

model investment_transactions {
  id            String   @id @default(cuid())
  user_id       String
  users         users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  investment_id String
  type          String // e.g., 'buy', 'sell'
  quantity      Decimal  @db.Decimal(18, 8)
  price         Decimal  @db.Decimal(18, 8)
  date          DateTime
  created_at    DateTime @default(now())

  @@index([user_id])
  @@index([investment_id])
}
